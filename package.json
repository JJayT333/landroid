{
  "name": "landroid",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "engines": {
    "node": ">=22 <26",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:watch": "vitest",
    "test:engine": "vitest run src/engine",
    "lint": "tsc --noEmit",
    "validate": "npm run lint && npm test && npm run build && npm run test:e2e && npm run validate:backend",
    "validate:backend": "npm --prefix backend/spine audit --omit=dev && npm test -- --config backend/spine/vitest.config.ts && tsc -p backend/spine/tsconfig.json --noEmit && npm --prefix backend/ai-proxy audit --omit=dev && npm --prefix backend/ai-proxy test && npm --prefix backend/ai-proxy run build",
    "deploy:check": "bash scripts/predeploy-check.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/openai-compatible": "^2.0.41",
    "@xyflow/react": "^12.4.0",
    "ai": "^6.0.168",
    "decimal.js": "^10.4.3",
    "dexie": "^4.0.11",
    "elkjs": "^0.11.1",
    "oidc-client-ts": "^3.5.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^3.0.4"
  }
}
